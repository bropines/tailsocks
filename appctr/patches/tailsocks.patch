+// --- MONOLITHIC FS PROVIDER BY HEDGEHOG ---
+
+type fsFileOps struct{ rootDir string }
+
+func (f fsFileOps) OpenWriter(name string, offset int64, perm os.FileMode) (io.WriteCloser, string, error) {
+	p, err := joinDir(f.rootDir, name)
+	if err != nil { return nil, "", err }
+	if err = os.MkdirAll(filepath.Dir(p), 0o700); err != nil { return nil, "", err }
+	fi, err := os.OpenFile(p, os.O_CREATE|os.O_RDWR, perm)
+	if err != nil { return nil, "", err }
+	if offset != 0 {
+		curr, err := fi.Seek(0, io.SeekEnd)
+		if err != nil { fi.Close(); return nil, "", err }
+		if offset < 0 || offset > curr { fi.Close(); return nil, "", fmt.Errorf("offset out of range") }
+		if _, err := fi.Seek(offset, io.SeekStart); err != nil { fi.Close(); return nil, "", err }
+		if err := fi.Truncate(offset); err != nil { fi.Close(); return nil, "", err }
+	}
+	return fi, p, nil
+}
+
+func (f fsFileOps) Remove(name string) error {
+	p, err := joinDir(f.rootDir, name)
+	if err != nil { return err }
+	return os.Remove(p)
+}
+
+func (f fsFileOps) Rename(oldPath, newName string) (newPath string, err error) {
+	if filepath.IsAbs(newName) || strings.ContainsRune(newName, os.PathSeparator) {
+		return "", fmt.Errorf("invalid newName")
+	}
+	dst := filepath.Join(f.rootDir, newName)
+	if err := os.MkdirAll(filepath.Dir(dst), 0o700); err != nil { return "", err }
+	st, err := os.Stat(oldPath)
+	if err != nil { return "", err }
+	wantSize := st.Size()
+
+	for i := 0; i < 10; i++ {
+		renameMu.Lock()
+		fi, statErr := os.Stat(dst)
+		if os.IsNotExist(statErr) {
+			err = os.Rename(oldPath, dst)
+			renameMu.Unlock()
+			return dst, err
+		}
+		renameMu.Unlock()
+		if statErr != nil { return "", statErr }
+		if fi.Size() == wantSize {
+			sumP, _ := sha256File(oldPath)
+			sumD, _ := sha256File(dst)
+			if bytes.Equal(sumP[:], sumD[:]) {
+				os.Remove(oldPath)
+				return dst, nil
+			}
+		}
+		dst = filepath.Join(filepath.Dir(dst), nextFilename(filepath.Base(dst)))
+	}
+	return "", fmt.Errorf("too many retries")
+}
+
+func sha256File(path string) (sum [sha256.Size]byte, _ error) {
+	f, err := os.Open(path)
+	if err != nil { return sum, err }
+	defer f.Close()
+	h := sha256.New()
+	io.Copy(h, f)
+	copy(sum[:], h.Sum(nil))
+	return sum, nil
+}
+
+func (f fsFileOps) ListFiles() ([]string, error) {
+	entries, err := os.ReadDir(f.rootDir)
+	if err != nil { return nil, err }
+	var names []string
+	for _, e := range entries {
+		if e.Type().IsRegular() { names = append(names, e.Name()) }
+	}
+	return names, nil
+}
+
+func (f fsFileOps) Stat(name string) (fs.FileInfo, error) {
+	p, err := joinDir(f.rootDir, name)
+	if err != nil { return nil, err }
+	return os.Stat(p)
+}
+
+func (f fsFileOps) OpenReader(name string) (io.ReadCloser, error) {
+	p, err := joinDir(f.rootDir, name)
+	if err != nil { return nil, err }
+	return os.Open(p)
+}
+
+func joinDir(dir, baseName string) (string, error) {
+	if !utf8.ValidString(baseName) || strings.TrimSpace(baseName) != baseName || len(baseName) > 255 {
+		return "", ErrInvalidFileName
+	}
+	clean := path.Clean(baseName)
+	if clean != baseName || clean == "." || clean == ".." { return "", ErrInvalidFileName }
+	if !filepath.IsLocal(baseName) { return "", ErrInvalidFileName }
+	return filepath.Join(dir, baseName), nil
+}
